# PostgreSQL (Prisma) — local or remote instance, no Docker required
DATABASE_URL=postgresql://postgres:your-password-here@localhost:5432/stockcountpro

# Auth — JWT session signing secret (min 32 chars; generate with: openssl rand -base64 32)
AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars
# Optional: force session cookie Secure flag (true/false).
# Default: follow request https / x-forwarded-proto (so LAN http://IP:3000 works with npm start).
# AUTH_COOKIE_SECURE=false

# Admin bootstrap (production) — store password in secret manager / deploy env only.
# Run once after migrate: npm run db:bootstrap-admin
# ADMIN_BOOTSTRAP_USERNAME=admin
# ADMIN_BOOTSTRAP_NAME=Admin
# ADMIN_BOOTSTRAP_BRANCH_CODE=BKK3
ADMIN_BOOTSTRAP_PASSWORD=replace-with-a-strong-admin-password
# Optional forced password reset on bootstrap: ADMIN_BOOTSTRAP_FORCE=1

# Express / Pode Stock Count API (server-side only — never expose to browser)
EXPRESS_API_BASE_URL=http://100.95.113.104:8080
EXPRESS_API_USERNAME=admin
EXPRESS_API_PASSWORD=your-password-here

# Log full Express push request/response in server console (1 = on)
# EXPRESS_PUSH_DEBUG=1

# Server timezone (UTC+7). npm start sets this automatically; set here for Docker/PM2 too.
TZ=Asia/Bangkok
